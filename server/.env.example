# Required — obtain from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Required — shared secret that clients must present to access the API
APP_PASSWORD=change-me

# Required — long random string used to sign JWTs (e.g. openssl rand -hex 32)
JWT_SECRET=change-me

# Required — PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/scribe

# Optional — comma-separated list of allowed CORS origins (defaults to all origins)
# ALLOWED_ORIGINS=https://your-app.vercel.app,https://other-origin.com

# Optional — OpenAI transcription model (defaults to gpt-4o-mini-transcribe)
# OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe

# Optional — port to listen on (defaults to 8000)
# PORT=8000
